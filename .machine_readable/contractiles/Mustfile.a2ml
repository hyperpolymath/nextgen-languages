# SPDX-License-Identifier: MPL-2.0
# Mustfile — hard-constraint contractile for nextgen-languages
#
# MUST is the hard-constraint contractile: invariants that are structurally
# required for the repository to function correctly and safely. Violating a
# MUST is always a bug — there are no "soft" MUSTs. MUST governs code,
# configuration, CI, and structure; style and preference live in CLAUDE.md.
# Trust never overrides MUST: even maximal-trust agents cannot violate it.
# All ADJUST invariants are implicitly MUST invariants too.
#
# Content ported 2026-06-12 from .machine_readable/MUST.contractile and
# contractiles/must/Mustfile.a2ml (both retired by the estate
# standardization; this flat file is now canonical).

[metadata]
repo = "nextgen-languages"
version = "2.0.0"
last-updated = "2026-06-12"
supersedes = [".machine_readable/MUST.contractile", "contractiles/must/Mustfile.a2ml"]

[universal.paths]
no-hardcoded-absolute-paths = "no /home/*, /mnt/*, /var/mnt/* in source"
path-style = "env vars, XDG dirs, or relative references"

[universal.language-policy]
no-new-typescript = true
no-new-python = true
no-new-go = true
package-manager = "Deno only — no npm/bun/yarn/pnpm dependencies"

[universal.dangerous-patterns]
idris2 = ["no believe_me", "no assert_total"]
coq = ["no Admitted"]
lean = ["no sorry"]
haskell = ["no unsafeCoerce"]
ocaml = ["no Obj.magic"]
rust = ["no unsafe {} blocks without safety comment"]

[universal.license]
spdx-header-on-every-source-file = true
license-file-immutable = "no removal or modification of LICENSE"

[universal.structure]
machine-readable-dir-preserved = true
ai-manifest-preserved = "0-AI-MANIFEST.a2ml preserved"
no-scm-in-root = "no SCM files in repo root — only in .machine_readable/"

[universal.ci]
no-workflow-removal-without-approval = true
actions-sha-pinned = "all GitHub Actions SHA-pinned"

[universal.quality]
tests-not-deleted-or-weakened = true
generated-code-location = "generated/ directory only"
no-owasp-top-10 = true

[universal.abi-ffi]
abi-contract-changes-require-proof-update = true
no-removal-of-formal-verification-proofs = true

# === Project-specific invariants (nextgen-languages) ===

[project.kitchenspeak]
postulates-trusted-base = "Agda postulates documented as trusted base (inline -- AXIOM: comment + PROOF-NEEDS.md)"
agda-proven-invariant = "proofs lead implementation (ADR 0001)"
echo-attachment = "Echo type attaches to Linear/Dyadic per ADR 0004; the Bool bridge is non-canonical"

[project.governance]
hypatia-advisories = "recurring Hypatia advisories are triaged in NEUROSYM.a2ml waivers, not silently suppressed"
upstream-rulesets = "echo-types and Hypatia rulesets are changed in their source repos, not vendored here"

# === Machine checks (from the retired root Mustfile; run: must check) ===

[checks.core-files]
license-present = { description = "LICENSE file must exist", run = "test -f LICENSE", severity = "critical" }
readme-present = { description = "README must exist", run = "test -f README.adoc || test -f README.md", severity = "critical" }
governance-docs = { description = "GOVERNANCE.adoc, MAINTAINERS.adoc, CODEOWNERS must exist", run = "test -f GOVERNANCE.adoc && test -f MAINTAINERS.adoc && test -f .github/CODEOWNERS", severity = "critical" }
contractiles-flat = { description = "flat contractile files exist", run = "test -f .machine_readable/contractiles/Mustfile.a2ml && test -f .machine_readable/contractiles/Trustfile.a2ml && test -f .machine_readable/contractiles/Intentfile.a2ml && test -f .machine_readable/contractiles/Adjustfile.a2ml && test -f .machine_readable/contractiles/Dustfile.a2ml && test -f .machine_readable/contractiles/Bustfile.a2ml", severity = "critical" }

[checks.kitchenspeak]
agda-proven-invariant = { description = "KitchenSpeak proofs directory must exist (proofs lead implementation)", run = "test -d kitchenspeak/proofs/agda", severity = "critical" }
kitchenspeak-lib-declared = { description = "kitchenspeak.agda-lib must declare echo-types dependency", run = "grep -q 'echo-types' kitchenspeak/proofs/agda/kitchenspeak.agda-lib", severity = "critical" }
kitchenspeak-postulates-annotated = { description = "all Agda postulates must be preceded by -- AXIOM: comment (trusted-base governance)", run = "! grep -n '^postulate' kitchenspeak/proofs/agda/*.agda | grep -v 'AXIOM' || true", severity = "warning" }
kitchenspeak-proof-needs-present = { description = "PROOF-NEEDS.md must enumerate postulate trusted base", run = "test -f kitchenspeak/proofs/PROOF-NEEDS.md", severity = "critical" }
kitchenspeak-adr-echo-attachment = { description = "ADR 0004 (Echo attaches to Linear/Dyadic) must be present", run = "test -f kitchenspeak/decisions/0004-echo-attaches-to-linear-dyadic.adoc", severity = "critical" }

[checks.banned]
no-hardcoded-paths = { description = "no hardcoded developer paths", run = "! grep -rn '/home/hyper\\|/mnt/eclipse' --include='*.rs' --include='*.res' --include='*.ex' --include='*.gleam' --include='*.zig' --include='*.sh' . 2>/dev/null | grep -v '.git/' | grep -v 'ux-rollout.jl' | head -1", severity = "critical" }
no-dockerfiles = { description = "no Dockerfiles (use Containerfile)", run = "test ! -f Dockerfile", severity = "warning" }
no-makefiles = { description = "no Makefiles (use Justfile)", run = "test ! -f Makefile", severity = "warning" }
